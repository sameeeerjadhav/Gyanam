<?php
/**
 * Database Configuration — Gyanam India Educational Services
 * Copy this file to db.php and fill in your credentials.
 */

define('DB_HOST', 'localhost');
define('DB_NAME', 'your_database_name');
define('DB_USER', 'your_database_user');
define('DB_PASS', 'your_database_password');
define('DB_CHARSET', 'utf8mb4');

// ─── Exam Portal API Integration ─────────────────────────────────────────────
define('EXAM_API_URL', 'https://your-exam-domain/gyanam-backend/public/index.php/api/v1');
define('EXAM_API_TOKEN', 'your_sanctum_token_here');

function getDBConnection(): PDO {
    static $pdo = null;
    if ($pdo === null) {
        $dsn = "mysql:host=" . DB_HOST . ";dbname=" . DB_NAME . ";charset=" . DB_CHARSET;
        $options = [
            PDO::ATTR_ERRMODE            => PDO::ERRMODE_EXCEPTION,
            PDO::ATTR_DEFAULT_FETCH_MODE => PDO::FETCH_ASSOC,
            PDO::ATTR_EMULATE_PREPARES   => false,
        ];
        try {
            $pdo = new PDO($dsn, DB_USER, DB_PASS, $options);
        } catch (PDOException $e) {
            error_log('Database Connection Error: ' . $e->getMessage());
            die('A system error occurred. Please try again later.');
        }
    }
    return $pdo;
}
